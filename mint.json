  "metadata": {
    "og:title": "FieldFlow Documentation",
    "og:description": "Learn how to turn your Google Sheets into beautiful, searchable web directories.",
    "og:image": "https://getfieldflow.io/og-image.png",
    "twitter:site": "@getfieldflow"
  }
