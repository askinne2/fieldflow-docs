{
  "$schema": "https://mintlify.com/schema.json",
  "name": "FieldFlow",
  "logo": {
    "light": "/logo/fieldflow-logo-light.svg",
    "dark": "/logo/fieldflow-logo-dark.svg"
  },
  "favicon": "/logo/fieldflow-favicon.svg",
  "colors": {
    "primary": "#2563eb",
    "light": "#3b82f6",
    "dark": "#1d4ed8",
    "anchors": {
      "from": "#2563eb",
      "to": "#1d4ed8"
    }
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://app.getfieldflow.io"
    }
