  },
  "tabs": [
    {
      "name": "FieldFlow Directory",
      "url": "saas"
    },
    {
      "name": "FieldFlow Sync",
      "url": "sync"
    }
  ],
  "anchors": [
    {
      "name": "Website",
      "icon": "globe",
      "url": "https://getfieldflow.io"
    },
    {
      "name": "Support",
      "icon": "envelope",
      "url": "mailto:hello@getfieldflow.io"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "saas/getting-started/introduction",
        "saas/getting-started/quick-start",
        "saas/getting-started/invite-your-team"
      ]
    },
    {
      "group": "Core Concepts",
      "pages": [
        "saas/core-concepts/how-sync-works",
        "saas/core-concepts/directory-structure",
        "saas/core-concepts/field-mapping",
        "saas/core-concepts/taxonomies-and-filters"
      ]
    },
    {
      "group": "Embedding",
      "pages": [
        "saas/embedding/embed-on-any-site",
        "saas/embedding/wordpress",
        "saas/embedding/custom-html"
      ]
    },
    {
      "group": "Account & Billing",
      "pages": [
        "saas/account/plans-and-limits",
        "saas/account/managing-your-team",
        "saas/account/billing-and-invoices"
      ]
    },
    {
      "group": "Troubleshooting",
      "pages": [
        "saas/troubleshooting/sync-errors",
        "saas/troubleshooting/google-sheets-permissions",
        "saas/troubleshooting/embed-not-showing"
      ]
    },
    {
      "group": "Getting Started",
      "pages": [
        "sync/getting-started/introduction"
      ]
    }
  ],
  "footerSocials": {
    "website": "https://getfieldflow.io"
  },
  "font": {
    "headings": {
      "family": "Inter"
